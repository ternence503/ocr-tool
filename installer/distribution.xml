<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>OCR 辨識工具</title>
    <welcome file="welcome.html"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>
    <domains enable_localSystem="true"/>
    <pkg-ref id="com.ternence.ocr-tool"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.ternence.ocr-tool"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.ternence.ocr-tool" visible="false">
        <pkg-ref id="com.ternence.ocr-tool"/>
    </choice>
    <pkg-ref id="com.ternence.ocr-tool" version="1.0.0" onConclusion="none">OCRTool-component.pkg</pkg-ref>
</installer-gui-script>
