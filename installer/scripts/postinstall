#!/bin/bash
# OCR 辨識工具 - postinstall script

# ── 取得實際登入使用者（postinstall 以 root 執行）──────────────
ACTUAL_USER=$(stat -f%Su /dev/console 2>/dev/null)
if [ -z "$ACTUAL_USER" ] || [ "$ACTUAL_USER" = "root" ]; then
    ACTUAL_USER=$(logname 2>/dev/null)
fi
if [ -z "$ACTUAL_USER" ] || [ "$ACTUAL_USER" = "root" ]; then
    ACTUAL_USER="$SUDO_USER"
fi
ACTUAL_HOME=$(eval echo "~$ACTUAL_USER")

INSTALL_DIR="$ACTUAL_HOME/.ocr-tool"
VENV_DIR="$INSTALL_DIR/.venv"
APP_PATH="/Applications/OCR辨識工具.app"
PAYLOAD_DIR="/Library/Application Support/OCRTool"
DONE_FILE="/tmp/ocr_install_done_$$"
PROGRESS_SCRIPT="/tmp/ocr_install_progress_$$.sh"

# ── 建立進度腳本（在 Terminal 視窗中執行）────────────────────────
cat > "$PROGRESS_SCRIPT" << SCRIPT
#!/bin/bash
clear
echo "┌─────────────────────────────────────────────┐"
echo "│         OCR 辨識工具 — 安裝進度             │"
echo "└─────────────────────────────────────────────┘"
echo ""
echo "  請勿關閉此視窗，安裝完成後會自動關閉。"
echo "  請保持網路連線，整個過程約需 5–15 分鐘。"
echo ""
echo "─────────────────────────────────────────────"

# 等待主腳本寫入各步驟結果
prev_line=""
while [ ! -f "$DONE_FILE" ]; do
    if [ -f "${DONE_FILE}.log" ]; then
        current=\$(cat "${DONE_FILE}.log" 2>/dev/null)
        if [ "\$current" != "\$prev_line" ]; then
            echo "\$current"
            prev_line="\$current"
        fi
    fi
    sleep 0.5
done

# 顯示最終結果
result=\$(cat "$DONE_FILE")
echo ""
if [ "\$result" = "ok" ]; then
    echo "─────────────────────────────────────────────"
    echo ""
    echo "  ✅ 安裝完成！"
    echo ""
    echo "  OCR 辨識工具已加入「應用程式」資料夾。"
    echo "  可從 Launchpad 或 Spotlight 搜尋「OCR」啟動。"
    echo ""
    echo "─────────────────────────────────────────────"
    echo ""
    echo "  此視窗將在 5 秒後關閉..."
    sleep 5
else
    echo "─────────────────────────────────────────────"
    echo ""
    echo "  ❌ 安裝失敗：\$result"
    echo ""
    echo "  請確認網路連線後，重新執行安裝程式。"
    echo "  若持續失敗，請截圖此畫面並回報問題。"
    echo ""
    echo "─────────────────────────────────────────────"
    echo "  按 Enter 關閉視窗..."
    read
fi
SCRIPT
chmod +x "$PROGRESS_SCRIPT"

log_step() {
    echo "$1" > "${DONE_FILE}.log"
}

# ── 開啟 Terminal 視窗給使用者看進度 ──────────────────────────
sudo -u "$ACTUAL_USER" osascript << APPLESCRIPT 2>/dev/null
tell application "Terminal"
    activate
    do script "$PROGRESS_SCRIPT"
    set bounds of front window to {200, 200, 900, 600}
end tell
APPLESCRIPT

# 等一秒讓 Terminal 開啟
sleep 1

# ── 尋找相容 Python（3.8–3.12）──────────────────────────────
log_step "  🔍 [1/5] 檢查 Python 版本..."

PYTHON_BIN=""
for candidate in python3.12 python3.11 python3.10 python3.9 python3.8; do
    bin_path=$(command -v "$candidate" 2>/dev/null)
    if [ -z "$bin_path" ]; then
        for prefix in /opt/homebrew/bin /usr/local/bin; do
            [ -x "$prefix/$candidate" ] && bin_path="$prefix/$candidate" && break
        done
    fi
    if [ -n "$bin_path" ]; then
        PYTHON_BIN="$bin_path"
        break
    fi
done

if [ -z "$PYTHON_BIN" ]; then
    echo "找不到 Python 3.8–3.12，請先安裝 Python 3.12" > "$DONE_FILE"
    sleep 2
    osascript -e 'display dialog "找不到相容的 Python（需要 3.8–3.12）。\n\n請先安裝 Python 3.12 後重新執行安裝程式：\nhttps://www.python.org/downloads/release/python-3129/" with title "OCR 辨識工具" buttons {"前往下載", "關閉"} default button "前往下載" with icon stop' 2>/dev/null | grep -q "前往下載" && \
        sudo -u "$ACTUAL_USER" open "https://www.python.org/downloads/release/python-3129/"
    exit 1
fi

PYVER=$("$PYTHON_BIN" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
log_step "  ✅ [1/5] Python $PYVER 已確認（$PYTHON_BIN）"
sleep 0.8

# ── 建立安裝目錄，複製腳本 ────────────────────────────────────
log_step "  📁 [2/5] 準備安裝目錄..."
mkdir -p "$INSTALL_DIR"
cp "$PAYLOAD_DIR/ocr.py" "$PAYLOAD_DIR/ocr_ui.py" "$INSTALL_DIR/"
chown "$ACTUAL_USER" "$INSTALL_DIR/ocr.py" "$INSTALL_DIR/ocr_ui.py"

# ── 建立虛擬環境 ──────────────────────────────────────────────
if [ ! -d "$VENV_DIR" ]; then
    sudo -u "$ACTUAL_USER" "$PYTHON_BIN" -m venv "$VENV_DIR"
fi
log_step "  ✅ [2/5] 安裝目錄準備完成"
sleep 0.8

# ── 安裝套件 ─────────────────────────────────────────────────
log_step "  📦 [3/5] 下載並安裝必要套件（約需 3–5 分鐘）..."
sudo -u "$ACTUAL_USER" "$VENV_DIR/bin/pip" install --upgrade pip -q 2>/dev/null
sudo -u "$ACTUAL_USER" "$VENV_DIR/bin/pip" install paddlepaddle paddleocr Pillow pymupdf -q 2>/dev/null

if [ $? -ne 0 ]; then
    echo "套件安裝失敗，請確認網路連線後重試" > "$DONE_FILE"
    sleep 2
    osascript -e 'display dialog "套件安裝失敗，請確認網路連線後重新執行安裝程式。" with title "OCR 辨識工具" buttons {"關閉"} default button "關閉" with icon stop' 2>/dev/null
    exit 1
fi
log_step "  ✅ [3/5] 套件安裝完成"
sleep 0.8

# ── 下載辨識模型 ──────────────────────────────────────────────
log_step "  🤖 [4/5] 下載中文辨識模型（約需 1–3 分鐘）..."
sudo -u "$ACTUAL_USER" env PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True \
    "$VENV_DIR/bin/python3" -c "
from paddleocr import PaddleOCR
PaddleOCR(
    lang='ch',
    text_detection_model_name='PP-OCRv5_mobile_det',
    text_recognition_model_name='PP-OCRv5_mobile_rec',
    use_doc_orientation_classify=False,
    use_doc_unwarping=False,
)
" 2>/dev/null

if [ $? -ne 0 ]; then
    echo "辨識模型下載失敗，請確認網路連線後重試" > "$DONE_FILE"
    sleep 2
    osascript -e 'display dialog "模型下載失敗，請確認網路連線後重新執行安裝程式。" with title "OCR 辨識工具" buttons {"關閉"} default button "關閉" with icon stop' 2>/dev/null
    exit 1
fi
log_step "  ✅ [4/5] 辨識模型下載完成"
sleep 0.8

# ── 建立 /Applications/OCR辨識工具.app ───────────────────────
log_step "  🖥  [5/5] 建立應用程式..."

# 產生 .icns 圖示
ICNS_PATH="$INSTALL_DIR/AppIcon.icns"
sudo -u "$ACTUAL_USER" env PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True \
    "$VENV_DIR/bin/python3" -c "
from PIL import Image, ImageDraw, ImageFont
import os, subprocess, shutil, tempfile

def load_font(size):
    for path in [
        '/Library/Fonts/Arial Unicode.ttf',
        '/System/Library/Fonts/Geneva.ttf',
        '/System/Library/Fonts/Monaco.ttf',
    ]:
        if os.path.exists(path):
            try: return ImageFont.truetype(path, size)
            except: pass
    return None

def make_frame(size):
    img = Image.new('RGBA', (size, size), (0,0,0,0))
    draw = ImageDraw.Draw(img)
    pad = max(1, size // 12)
    r = max(2, size // 4)
    draw.rounded_rectangle([pad, pad, size-pad-1, size-pad-1], radius=r, fill=(30,115,220,255))
    if size >= 48:
        for y in range(pad+r+2, size-pad-r-2, max(3, size//20)):
            draw.line([(pad+r,y),(size-pad-r,y)], fill=(255,255,255,35), width=1)
    font = load_font(max(6, int(size*0.38)))
    if font:
        text = 'OCR'
        bbox = draw.textbbox((0,0), text, font=font)
        tw, th = bbox[2]-bbox[0], bbox[3]-bbox[1]
        tx = (size-tw)//2 - bbox[0]
        ty = (size-th)//2 - bbox[1]
        if size >= 32:
            draw.text((tx+1,ty+1), text, font=font, fill=(0,0,0,80))
        draw.text((tx,ty), text, font=font, fill=(255,255,255,255))
    return img

iconset = tempfile.mkdtemp(suffix='.iconset')
for s, name in [(16,'16x16'),(32,'16x16@2x'),(32,'32x32'),(64,'32x32@2x'),
                (128,'128x128'),(256,'128x128@2x'),(256,'256x256'),
                (512,'256x256@2x'),(512,'512x512'),(1024,'512x512@2x')]:
    make_frame(s).save(f'{iconset}/icon_{name}.png')
subprocess.run(['iconutil','-c','icns',iconset,'-o','$ICNS_PATH'], check=True)
shutil.rmtree(iconset)
" 2>/dev/null

rm -rf "$APP_PATH"
mkdir -p "$APP_PATH/Contents/MacOS" "$APP_PATH/Contents/Resources"

if [ -f "$ICNS_PATH" ]; then
    cp "$ICNS_PATH" "$APP_PATH/Contents/Resources/AppIcon.icns"
fi

cat > "$APP_PATH/Contents/MacOS/OCR辨識工具" << EXEC
#!/bin/bash
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True "$VENV_DIR/bin/python3" "$INSTALL_DIR/ocr_ui.py" 2>/dev/null
EXEC
chmod +x "$APP_PATH/Contents/MacOS/OCR辨識工具"

cat > "$APP_PATH/Contents/Info.plist" << 'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>OCR辨識工具</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundleName</key>
    <string>OCR辨識工具</string>
    <key>CFBundleDisplayName</key>
    <string>OCR 辨識工具</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleIdentifier</key>
    <string>com.ternence.ocr-tool</string>
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
</dict>
</plist>
PLIST

chown -R "$ACTUAL_USER" "$APP_PATH"
chown -R "$ACTUAL_USER" "$INSTALL_DIR"

log_step "  ✅ [5/5] 應用程式建立完成"

# ── 清理 ──────────────────────────────────────────────────────
rm -rf "$PAYLOAD_DIR"
rm -f "${DONE_FILE}.log"

# 通知進度視窗完成
echo "ok" > "$DONE_FILE"

# 清理暫存腳本
sleep 8
rm -f "$PROGRESS_SCRIPT" "$DONE_FILE"

exit 0
